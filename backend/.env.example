# Performance Testing Platform — Backend API Environment Variables

# Server
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=perfplatform
DB_USER=perfplatform
DB_PASSWORD=perfplatform123

# Kubernetes
# If running inside cluster, service account token is used automatically.
# For local dev, set KUBECONFIG or let it auto-detect ~/.kube/config
KUBE_NAMESPACE=perf-testing
# KUBECONFIG=/home/user/.kube/config

# JMeter Docker Images
JMETER_IMAGE=jmeter-base:5.6.3
REPORT_GENERATOR_IMAGE=jmeter-report-generator:latest

# Results storage path (must match PVC mount path in K8s)
RESULTS_PATH=/results

# Logging
LOG_LEVEL=info

# Scheduler (leave blank to disable cron scheduler in dev)
# DISABLE_SCHEDULER=true
