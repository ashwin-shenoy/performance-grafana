<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  FILE     : sample.jmx
  PURPOSE  : Multi-thread-group JMeter test plan for the sample-app service.
             Streams real-time metrics to InfluxDB 2.x for live Grafana
             monitoring. Designed to be triggered by the perf-platform API.

  THREAD GROUPS (2):
    Browse   — catalogue browsing (GET-heavy, higher concurrency)
    Checkout — full purchase journey (POST-heavy, lower concurrency)

  RUNTIME FLAGS (injected by ExecutionService.js):
    Global (legacy single-group fallback):
      -Jthreads         Global virtual user count
      -JrampUp          Global ramp-up seconds
      -Jduration        Global test duration seconds

    Per-thread-group (injected by the RunDialog per-group config):
      -Jbrowse_users      Browse: virtual users   (default: 5)
      -Jbrowse_rampup     Browse: ramp-up seconds (default: 30)
      -Jbrowse_duration   Browse: duration seconds (default: 180)
      -Jbrowse_thinktime  Browse: think time ms    (default: 500)

      -Jcheckout_users      Checkout: virtual users   (default: 2)
      -Jcheckout_rampup     Checkout: ramp-up seconds (default: 30)
      -Jcheckout_duration   Checkout: duration seconds (default: 180)
      -Jcheckout_thinktime  Checkout: think time ms    (default: 800)

    Identity (always injected):
      -Jworkload_name   Workload name slug (InfluxDB "application" tag)
      -Jtest_run_id     Execution ID       (annotation labels)

    Target service:
      -Jhost            Target host (default: sample-app)
      -Jport            Target port (default: 3002)

    InfluxDB (standalone mode overrides Docker default):
      -JinfluxdbUrl     InfluxDB write endpoint
      -JinfluxdbToken   InfluxDB API token

  INFLUXDB SCHEMA:
    Measurement : jmeter
    Tags written per data point:
      application   = ${workload_name}   ← workload filter in Grafana
      transaction   = sampler name | "all" | "internal"
      statut        = "ok" | "ko" | "all"
    Fields per ~1s interval:
      avg, min, max, pct90.0, pct95.0, pct99.0   response time (ms)
      throughput                                   requests/sec
      hit, count, countError                       sample counts
      rb, sb                                       bytes in/out

  SAMPLERS:
    Browse group (3):
      1. GET  /health              liveness probe
      2. GET  /api/products        catalogue browse (~150ms, ~5% error)
      3. GET  /api/products/:id    product detail  (~50ms,  ~5% error)
    Checkout group (2):
      4. GET  /api/users/:id       profile lookup  (~70ms,  ~5% error)
      5. POST /api/orders          place order     (~320ms, ~5% error)
  ============================================================================
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <!-- ====================================================================
         TEST PLAN
         User-Defined Variables are resolved once at startup.  All -J flags
         override the ${__P(...)} defaults at runtime.
         ==================================================================== -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="Sample App Load Test — Multi-Thread-Group" enabled="true">
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <!-- false = run all thread groups concurrently -->
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>

      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments" enabled="true">
        <collectionProp name="Arguments.arguments">

          <!-- ── Target service ─────────────────────────────────────────── -->
          <elementProp name="TARGET_HOST" elementType="Argument">
            <stringProp name="Argument.name">TARGET_HOST</stringProp>
            <stringProp name="Argument.value">${__P(host,sample-app)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="TARGET_PORT" elementType="Argument">
            <stringProp name="Argument.name">TARGET_PORT</stringProp>
            <stringProp name="Argument.value">${__P(port,3002)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- ── InfluxDB 2.x write target ─────────────────────────────── -->
          <elementProp name="INFLUXDB_URL" elementType="Argument">
            <stringProp name="Argument.name">INFLUXDB_URL</stringProp>
            <stringProp name="Argument.value">${__P(influxdbUrl,http://influxdb:8086/api/v2/write?org=perf-testing&amp;bucket=jmeter)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="INFLUXDB_TOKEN" elementType="Argument">
            <stringProp name="Argument.name">INFLUXDB_TOKEN</stringProp>
            <stringProp name="Argument.value">${__P(influxdbToken,changeme123)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- ── Workload identity ──────────────────────────────────────── -->
          <elementProp name="WORKLOAD_NAME" elementType="Argument">
            <stringProp name="Argument.name">WORKLOAD_NAME</stringProp>
            <stringProp name="Argument.value">${__P(workload_name,sample-app)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="TEST_RUN_ID" elementType="Argument">
            <stringProp name="Argument.name">TEST_RUN_ID</stringProp>
            <stringProp name="Argument.value">${__P(test_run_id,0)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

        </collectionProp>
      </elementProp>
      <stringProp name="TestPlan.comments">
        Two-group e-commerce load test.
        Browse: catalogue browsing (GET-heavy).
        Checkout: purchase journey (POST-heavy).
        Metrics stream to InfluxDB tagged with workload_name + test_run_id.
      </stringProp>
    </TestPlan>
    <hashTree>

      <!-- ==================================================================
           SHARED CONFIG (test-plan level — applies to ALL thread groups)
           ================================================================== -->

      <!-- HTTP Request Defaults — all samplers inherit host / port -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement"
                         testname="HTTP Request Defaults" enabled="true">
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                     guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.domain">${TARGET_HOST}</stringProp>
        <stringProp name="HTTPSampler.port">${TARGET_PORT}</stringProp>
        <stringProp name="HTTPSampler.protocol">http</stringProp>
        <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
        <stringProp name="HTTPSampler.path"/>
        <boolProp name="HTTPSampler.image_parser">false</boolProp>
        <boolProp name="HTTPSampler.concurrentDwn">false</boolProp>
        <stringProp name="HTTPSampler.connect_timeout">5000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">15000</stringProp>
      </ConfigTestElement>
      <hashTree/>

      <!-- JSON Accept/Content-Type headers for all requests -->
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                     testname="HTTP Headers" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Content-Type</stringProp>
            <stringProp name="Header.value">application/json</stringProp>
          </elementProp>
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">application/json</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <!-- ==================================================================
           BACKEND LISTENER — InfluxDB 2.x real-time metrics
           Placed at test-plan level so it captures data from ALL thread groups.

           application  = ${WORKLOAD_NAME}
             → InfluxDB "application" tag on EVERY data point (both groups).
             → Grafana var-workload_name dropdown is populated from this tag.

           testTitle    = "Run #${TEST_RUN_ID}"
             → Labels testStarted / testEnded event annotations.

           eventTags    = "workload_name=X,test_run_id=Y"
             → Extra tags on the events measurement (start/stop markers).
           ================================================================== -->
      <BackendListener guiclass="BackendListenerGui" testclass="BackendListener"
                       testname="InfluxDB 2.x Backend Listener" enabled="true">
        <elementProp name="arguments" elementType="Arguments"
                     guiclass="ArgumentsPanel" testclass="Arguments"
                     testname="User Defined Variables" enabled="true">
          <collectionProp name="Arguments.arguments">

            <elementProp name="influxdbMetricsSender" elementType="Argument">
              <stringProp name="Argument.name">influxdbMetricsSender</stringProp>
              <stringProp name="Argument.value">org.apache.jmeter.visualizers.backend.influxdb.HttpMetricsSender</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="influxdbUrl" elementType="Argument">
              <stringProp name="Argument.name">influxdbUrl</stringProp>
              <stringProp name="Argument.value">${INFLUXDB_URL}</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="influxdbToken" elementType="Argument">
              <stringProp name="Argument.name">influxdbToken</stringProp>
              <stringProp name="Argument.value">${INFLUXDB_TOKEN}</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="application" elementType="Argument">
              <stringProp name="Argument.name">application</stringProp>
              <stringProp name="Argument.value">${WORKLOAD_NAME}</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="measurement" elementType="Argument">
              <stringProp name="Argument.name">measurement</stringProp>
              <stringProp name="Argument.value">jmeter</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <!-- false = per-sampler rows + aggregate "all" row -->
            <elementProp name="summaryOnly" elementType="Argument">
              <stringProp name="Argument.name">summaryOnly</stringProp>
              <stringProp name="Argument.value">false</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="samplersRegex" elementType="Argument">
              <stringProp name="Argument.name">samplersRegex</stringProp>
              <stringProp name="Argument.value">.*</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <!-- P90 = pct90.0, P95 = pct95.0, P99 = pct99.0 in InfluxDB -->
            <elementProp name="percentiles" elementType="Argument">
              <stringProp name="Argument.name">percentiles</stringProp>
              <stringProp name="Argument.value">90;95;99</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="testTitle" elementType="Argument">
              <stringProp name="Argument.name">testTitle</stringProp>
              <stringProp name="Argument.value">Run #${TEST_RUN_ID}</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

            <elementProp name="eventTags" elementType="Argument">
              <stringProp name="Argument.name">eventTags</stringProp>
              <stringProp name="Argument.value">workload_name=${WORKLOAD_NAME},test_run_id=${TEST_RUN_ID}</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>

          </collectionProp>
        </elementProp>
        <stringProp name="classname">org.apache.jmeter.visualizers.backend.influxdb.InfluxdbBackendListenerClient</stringProp>
      </BackendListener>
      <hashTree/>

      <!-- ==================================================================
           THREAD GROUP 1 — Browse
           Simulates catalogue-browsing users: health check, product list,
           product detail.  Higher concurrency, shorter think time.

           JMeter properties read:
             -Jbrowse_users    → virtual user count   (default 5)
             -Jbrowse_rampup   → ramp-up seconds      (default 30)
             -Jbrowse_duration → duration seconds     (default 180)
             -Jbrowse_thinktime→ think time ms (timer delay) (default 500)
           ================================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="Browse" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(browse_users,5)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(browse_rampup,30)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${__P(browse_duration,180)}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- ================================================================
             SAMPLER B1 — GET /health
             Liveness probe. Strict 200 assertion; any failure shows in Grafana
             error panel immediately.
             ================================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /health" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">/health</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Expect 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Health check must return HTTP 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- Think time between Browse samplers — controlled by -Jbrowse_thinktime -->
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer"
                            testname="Browse Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">${__P(browse_thinktime,500)}</stringProp>
          <stringProp name="RandomTimer.range">300</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ================================================================
             SAMPLER B2 — GET /api/products
             Catalogue browse (~150ms, ~5% error rate).
             ================================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /api/products" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/products</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer"
                            testname="Browse Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">${__P(browse_thinktime,500)}</stringProp>
          <stringProp name="RandomTimer.range">300</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ================================================================
             SAMPLER B3 — GET /api/products/:id
             Product detail page. Stores productId for reuse in Checkout group.
             ================================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /api/products/:id" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/products/${__Random(1,5,productId)}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer"
                            testname="Browse Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">${__P(browse_thinktime,500)}</stringProp>
          <stringProp name="RandomTimer.range">300</stringProp>
        </UniformRandomTimer>
        <hashTree/>

      </hashTree>

      <!-- ==================================================================
           THREAD GROUP 2 — Checkout
           Simulates purchase-journey users: profile lookup + order placement.
           Lower concurrency, longer think time (deliberate buy intent).

           JMeter properties read:
             -Jcheckout_users     → virtual user count   (default 2)
             -Jcheckout_rampup    → ramp-up seconds      (default 30)
             -Jcheckout_duration  → duration seconds     (default 180)
             -Jcheckout_thinktime → think time ms (timer delay) (default 800)
           ================================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="Checkout" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(checkout_users,2)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(checkout_rampup,30)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${__P(checkout_duration,180)}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- ================================================================
             SAMPLER C1 — GET /api/users/:id
             Simulates profile lookup before checkout (~70ms, ~5% error).
             ================================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /api/users/:id" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/users/${__Random(1,1000,userId)}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- Think time between Checkout samplers — controlled by -Jcheckout_thinktime -->
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer"
                            testname="Checkout Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">${__P(checkout_thinktime,800)}</stringProp>
          <stringProp name="RandomTimer.range">400</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ================================================================
             SAMPLER C2 — POST /api/orders
             Heaviest endpoint (~320ms). Accepts 201 (success) and
             500 (simulated payment timeout ~5%) so errors are counted in
             InfluxDB countError but the test keeps running.
             ================================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="POST /api/orders" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"productId": ${__Random(1,5,pId)}, "quantity": ${__Random(1,3,qty)}}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/orders</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 201 or 500" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">201</stringProp>
              <stringProp name="49587">500</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Order must return 201 or 500 (simulated error)</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">40</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer"
                            testname="Checkout Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">${__P(checkout_thinktime,800)}</stringProp>
          <stringProp name="RandomTimer.range">400</stringProp>
        </UniformRandomTimer>
        <hashTree/>

      </hashTree>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
